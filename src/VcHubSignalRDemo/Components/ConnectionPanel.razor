<div class="card h-100">
    <div class="card-header">
        Connection
    </div>
    <div class="card-body d-flex flex-column gap-2">
        <label class="form-label">VC Hub Url</label>
        <input class="form-control" @bind="Settings.Url" />

        <label class="form-label">Client ID</label>
        <input class="form-control" @bind="Settings.ClientId" />

        <label class="form-label">Client Secret</label>
        <input type="password" class="form-control" @bind="Settings.ClientSecret" />

        <label class="form-label">SignalR Route</label>
        <input class="form-control" @bind="Settings.PrimaryRoute" />

        <div class="mt-2">
            <span class="badge @(IsConnected ? "text-bg-success" : "text-bg-secondary")">@ConnectionStatus</span>
        </div>

        <div class="d-flex gap-2 mt-2">
            <button class="btn btn-outline-primary" disabled="@IsBusy" @onclick="OnTestAuth">Test Auth</button>
            <button class="btn btn-success" disabled="@(IsBusy || IsConnected)" @onclick="OnConnect">Connect</button>
            <button class="btn btn-outline-danger" disabled="@(IsBusy || !IsConnected)" @onclick="OnDisconnect">Disconnect</button>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public ConnectionSettings Settings { get; set; } = new();

    [Parameter]
    public string ConnectionStatus { get; set; } = "Disconnected";

    [Parameter]
    public bool IsConnected { get; set; }

    [Parameter]
    public bool IsBusy { get; set; }

    [Parameter]
    public EventCallback OnTestAuth { get; set; }

    [Parameter]
    public EventCallback OnConnect { get; set; }

    [Parameter]
    public EventCallback OnDisconnect { get; set; }
}
